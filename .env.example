VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# simulation : revue manuelle dans /fondateur?section=kyc
# external   : decisions manuelles masquees, statuts recus du service KYC
VITE_KYC_MODE=simulation

# Stripe — SEULE la cle publishable va cote client (non sensible).
# La cle secrete (sk_test_...) et le secret webhook (whsec_...) se configurent
# uniquement en secrets Edge Functions : voir docs/stripe-deployment.md.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
